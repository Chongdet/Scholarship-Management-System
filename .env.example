# Copy to .env and fill in your values

# Database
DATABASE_URL=sqlite:///scholarship.db

# Email - Mailtrap API (ใช้ส่งอีเมลจริง)
# ลงทะเบียนที่ mailtrap.io เพื่อรับ API Token
# MAILTRAP_API_TOKEN=your-mailtrap-api-token

# อีเมลผู้ส่ง - Mailtrap ต้องใช้โดเมนที่ยืนยันแล้ว เช่น hello@demomailtrap.co
# SYSTEM_EMAIL=hello@demomailtrap.co

# SMTP (สำรอง เมื่อไม่มี MAILTRAP_API_TOKEN)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# (ตัวเลือก) ส่งแจ้งเตือนมาที่อีเมลนี้แทนนักศึกษา - ใช้ตอนทดสอบ
# EMAIL_OVERRIDE=your-test-email@example.com
