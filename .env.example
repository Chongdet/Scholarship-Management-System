# Copy to .env and fill in your values

# Database
DATABASE_URL=sqlite:///scholarship.db

# ========== Email - ส่งอีเมลจริงไปให้นักศึกษา (เลือกอย่างใดอย่างหนึ่ง) ==========

# --- วิธีที่ 1: Gmail SMTP (แนะนำ - ส่งได้ทันที ไม่ต้องยืนยันโดเมน) ---
# ใช้ได้กับ Gmail หรือ Google Workspace (เช่น @ubu.ac.th ที่ใช้ Gmail ของมหาลัย)
# 1. เปิด 2-Step Verification ที่ myaccount.google.com/security
# 2. สร้าง App Password ที่ myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=ใส่-App-Password-16-ตัว
SYSTEM_EMAIL=your-email@gmail.com

# --- วิธีที่ 2: Mailtrap API (ต้องเพิ่มและยืนยันโดเมนใน Mailtrap ก่อน) ---
# MAILTRAP_API_TOKEN=your-mailtrap-api-token
# SYSTEM_EMAIL=email@โดเมนที่ยืนยันแล้ว.com

# (ตัวเลือก) ส่งแจ้งเตือนมาที่อีเมลนี้แทนนักศึกษา - ใช้ตอนทดสอบ
# EMAIL_OVERRIDE=your-test-email@example.com
